generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BoardRole {
  OWNER
  MEMBER
}

enum UserRole {
  USER
  ADMIN
}

enum CardActivityType {
  CREATED
  MOVED
  RENAMED
  DESCRIPTION_UPDATED
  DUE_DATE_CHANGED
  ARCHIVED
  UNARCHIVED
  CHECKLIST_ITEM_ADDED
  CHECKLIST_ITEM_COMPLETED
  CHECKLIST_ITEM_UNCOMPLETED
  CHECKLIST_ITEM_REMOVED
}

/// How often a recurring-task template spawns a fresh occurrence. Stored as an
/// enum so new cadences (DAILY/MONTHLY) can be added without a data migration;
/// only WEEKLY is implemented today.
enum RecurrenceCadence {
  WEEKLY
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  refreshTokens  RefreshToken[]
  boardMemberships BoardMember[]
  createdCards   Card[]         @relation("CardCreator")
  ownedBoards    Board[]        @relation("BoardOwner")
  cardActivities CardActivity[] @relation("CardActivityActor")
  createdRecurringTasks   RecurringTask[]  @relation("RecurringTaskCreator")
  completedChecklistItems ChecklistItem[]  @relation("ChecklistItemCompleter")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Board {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner   User          @relation("BoardOwner", fields: [ownerId], references: [id])
  members BoardMember[]
  lists   List[]
  recurringTasks RecurringTask[]

  @@index([ownerId])
}

model BoardMember {
  id       String    @id @default(cuid())
  boardId  String
  userId   String
  role     BoardRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

model List {
  id         String   @id @default(cuid())
  boardId    String
  name       String
  position   String
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]
  recurringTasks RecurringTask[] @relation("RecurringTaskTargetList")

  @@index([boardId, position])
}

model Card {
  id          String    @id @default(cuid())
  listId      String
  boardId     String
  title       String
  description String?
  position    String
  dueDate     DateTime?
  isArchived  Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // When this card is a spawned occurrence of a recurring task, these link it
  // back to its template and record which period (the Monday 00:00 UTC of the
  // week) it represents. Null for ordinary, one-off cards.
  recurringTaskId String?
  occurrenceStart DateTime?

  list          List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdBy     User            @relation("CardCreator", fields: [createdById], references: [id])
  recurringTask RecurringTask?  @relation(fields: [recurringTaskId], references: [id], onDelete: SetNull)
  activities    CardActivity[]
  checklist     ChecklistItem[]

  @@unique([recurringTaskId, occurrenceStart])
  @@index([listId, position])
  @@index([boardId, isArchived])
}

/// A recurring-task template: a repeatable chore (e.g. "تنظيف المعهد") whose
/// fixed set of subtasks is snapshotted onto a fresh Card each period. The
/// template itself is never "done"; each spawned occurrence Card is.
model RecurringTask {
  id           String            @id @default(cuid())
  boardId      String
  targetListId String
  title        String
  description  String?
  cadence      RecurrenceCadence @default(WEEKLY)
  isActive     Boolean           @default(true)
  position     String
  createdById  String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  board      Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  targetList List              @relation("RecurringTaskTargetList", fields: [targetListId], references: [id], onDelete: Cascade)
  createdBy  User              @relation("RecurringTaskCreator", fields: [createdById], references: [id])
  subtasks   RecurringSubtask[]
  cards      Card[]

  @@index([boardId, position])
}

/// One subtask of a recurring template. Its identity (`id`) is *stable across
/// weeks* — every ChecklistItem spawned from it links back here, which is what
/// lets a report ask "was 'غسل الدرج' done every week last month?".
model RecurringSubtask {
  id              String   @id @default(cuid())
  recurringTaskId String
  label           String
  position        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  recurringTask RecurringTask   @relation(fields: [recurringTaskId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]

  @@index([recurringTaskId, position])
}

/// A single tick-box on a card. Ad-hoc items on any card have a null
/// `recurringSubtaskId`; items spawned from a recurring template carry the
/// subtask link (for reporting) plus a snapshot of its `label`.
model ChecklistItem {
  id                String    @id @default(cuid())
  cardId            String
  recurringSubtaskId String?
  label             String
  position          String
  isCompleted       Boolean   @default(false)
  completedAt       DateTime?
  completedById     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  card             Card              @relation(fields: [cardId], references: [id], onDelete: Cascade)
  recurringSubtask RecurringSubtask? @relation(fields: [recurringSubtaskId], references: [id], onDelete: SetNull)
  completedBy      User?             @relation("ChecklistItemCompleter", fields: [completedById], references: [id])

  @@index([cardId, position])
  @@index([recurringSubtaskId])
}

/// Append-only audit trail for a card ("task"): who created it, and who
/// changed its status (list), title, description, due date, or archived
/// state — and when. Rows are never mutated, only inserted, so the ordered
/// stream is the card's full history. Deleting a card cascades its history.
model CardActivity {
  id        String           @id @default(cuid())
  cardId    String
  boardId   String
  actorId   String
  type      CardActivityType
  fromValue String?
  toValue   String?
  createdAt DateTime         @default(now())

  card  Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  actor User @relation("CardActivityActor", fields: [actorId], references: [id])

  @@index([cardId, createdAt])
}
